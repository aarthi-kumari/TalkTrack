# Clerk (Dashboard → API Keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Optional: JWT template name if Express returns 401 (Clerk Dashboard → JWT Templates)
# NEXT_PUBLIC_CLERK_JWT_TEMPLATE="meeting-ai"

# Clerk routes
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# Express API — empty uses Next.js rewrite to http://127.0.0.1:5000 (dev)
# NEXT_PUBLIC_API_URL=
# Socket.IO — empty uses same-origin (proxied via Next.js rewrites)
# NEXT_PUBLIC_SOCKET_URL=

# LiveKit Cloud — required for video/audio (https://cloud.livekit.io)
# Must match LIVEKIT_URL in server/.env
NEXT_PUBLIC_LIVEKIT_URL="wss://your-project.livekit.cloud"
