# PostgreSQL (Supabase connection string)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Clerk (Dashboard → API Keys)
CLERK_SECRET_KEY="sk_test_..."
# Must match NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY in client/.env.local
CLERK_PUBLISHABLE_KEY="pk_test_..."

# Clerk Webhooks (Dashboard → Webhooks → Signing secret)
# Local: expose port 5000 with ngrok, set endpoint to https://<tunnel>/api/webhooks/clerk
CLERK_WEBHOOK_SIGNING_SECRET="whsec_..."

# Redis (BullMQ — Phase 4+)
REDIS_URL="redis://localhost:6379"

# LiveKit Cloud (Phase 1+)
LIVEKIT_API_KEY=""
LIVEKIT_API_SECRET=""
LIVEKIT_URL="wss://your-project.livekit.cloud"

# AI providers (later phases)
DEEPGRAM_API_KEY=""
GROQ_API_KEY=""
GOOGLE_AI_API_KEY=""
ELEVENLABS_API_KEY=""

# Client origin for CORS
CLIENT_URL="http://localhost:3000"
